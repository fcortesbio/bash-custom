#!/usr/bin/env bash

TARGET="$HOME/.bashrc"
SKELETON="/etc/skel/.bashrc"

HOOK='[[ $- != *i* ]] && return
[[ -f ~/Scripts/main.sh ]] && source ~/Scripts/main.sh'

echo "Checking $TARGET..."

# Ensure file exists
touch "$TARGET"

NEEDS_BACKUP=false

if [[ -s "$TARGET" ]]; then
    if [[ -f "$SKELETON" ]] && cmp -s "$TARGET" "$SKELETON"; then
        echo ".bashrc matches Arch skeleton. No backup needed."
    else
        echo ".bashrc differs from skeleton. Creating backup."
        NEEDS_BACKUP=true
    fi
else
    echo ".bashrc is empty."
fi

if $NEEDS_BACKUP && [[ ! -f "$HOME/.bashrc.bak" ]]; then
    cp "$TARGET" "$HOME/.bashrc.bak.$(date +%F-%H%M%S)"
    echo "Backup saved to ~/.bashrc.bak"
fi

echo "Rewriting $TARGET..."

# Truncate file
: > "$TARGET"

# Write hook
printf "%s\n" "$HOOK" >> "$TARGET"

echo ".bashrc updated."

read -rp "Reload shell now? [Y/N]: " answer
case "$answer" in
    [Yy])
        exec "$SHELL"
        ;;
    *)
        echo "Open a new shell or run: source ~/.bashrc"
        ;;
esac